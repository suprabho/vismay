# Expo + pnpm: hoist all Babel presets/plugins to the root node_modules so
# Metro/Babel can resolve them under pnpm's strict (isolated) layout.
# Without this, transitive Babel deps (babel-preset-expo and the @babel/*
# plugins it pulls in) aren't resolvable from app code and `expo export:embed`
# (the EAS "Bundle JavaScript" / Gradle createBundleRelease task) fails.
public-hoist-pattern[]=*babel*
# Preserve pnpm's default public hoists.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
