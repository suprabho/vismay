{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@vismay/viz-engine/src/lib/genSchema": ["./src/viz-engine-stubs/genSchema"],
      "@vismay/viz-engine/src/registry": ["./src/viz-engine-stubs/registry"],
      "@vismay/viz-engine/src/foregroundLayouts": ["./src/viz-engine-stubs/foregroundLayouts"],
      "@vismay/viz-engine/src/lib/schemaDocs": ["./src/viz-engine-stubs/schemaDocs"],
      "@vismay/content-source/storySection": ["./src/viz-engine-stubs/contentSource-storySection"]
    }
  },
  "include": ["src/**/*"]
}
