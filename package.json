{
  "name": "vismay",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "mcp:dev": "tsx scripts/mcp-dev.mts",
    "mcp:catalog": "PORT=3100 pnpm --filter @vismay/catalog dev",
    "gen:sources": "tsx scripts/gen-tailwind-sources.mts"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "turbo": "^2.5.0",
    "typescript": "^5"
  }
}
