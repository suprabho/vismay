# VizF1 FastF1 ingestion worker — Supabase service-role creds.
# Env precedence mirrors the TS worker (apps/vizf1/worker/src/supabase.ts).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Where FastF1 caches its downloads. CI should cache this dir (it is slow to
# repopulate and the F1 API is rate-limited).
FASTF1_CACHE_DIR=/tmp/fastf1_cache
