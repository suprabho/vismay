{
  "name": "@vizf1/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ingest:news": "tsx --env-file=.env src/ingestNews.ts",
    "ingest:news:ci": "tsx src/ingestNews.ts",
    "ingest:sessions": "tsx --env-file=.env src/ingestSessions.ts",
    "ingest:sessions:ci": "tsx src/ingestSessions.ts",
    "ingest:circuits": "tsx --env-file=.env src/ingestCircuits.ts",
    "ingest:circuits:ci": "tsx src/ingestCircuits.ts",
    "backfill:driver-meta": "tsx --env-file=.env src/backfillDriverMeta.ts",
    "backfill:driver-meta:ci": "tsx src/backfillDriverMeta.ts",
    "build:story-segments": "tsx --env-file=.env src/buildStorySegments.ts",
    "build:story-segments:ci": "tsx src/buildStorySegments.ts",
    "capture:replay": "tsx src/captureReplayFixture.ts",
    "gen:replay-fixture": "node scripts/genSyntheticReplayFixture.mjs",
    "eval": "tsx --env-file=.env src/eval/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@supabase/supabase-js": "^2.45.4",
    "@vismay/eval-entities": "workspace:*",
    "@vizf1/brand": "workspace:*",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
