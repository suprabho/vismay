# apps/worker/.env — server-only secrets. Never commit .env, never ship to the client.
# Copy this file to .env and fill in real values.

# ──────────────────────────────────────────────────────────
# Supabase — project URL and service-role key
# Get from: Supabase dashboard → Settings → API
# ──────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...           # service_role key (NOT anon)

# ──────────────────────────────────────────────────────────
# Gemini — used by apps/worker/src/gemini.ts for summarization + entity extraction
# Get from: https://aistudio.google.com → Get API key (free tier, no card)
# ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash                # optional override; default is flash

# ──────────────────────────────────────────────────────────
# football-data.org — used by apps/worker/src/seed.ts to populate leagues + teams
# Get from: https://www.football-data.org/client/register (free tier: 10 req/min)
# Upgrade to Standard (€29–49/mo) before commercial launch
# ──────────────────────────────────────────────────────────
FOOTBALL_DATA_TOKEN=
