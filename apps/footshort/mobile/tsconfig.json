{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "nativewind",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "types": ["react", "react-native"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "app/**/*",
    "src/**/*",
    "app.config.ts",
    "nativewind-env.d.ts"
  ]
}
