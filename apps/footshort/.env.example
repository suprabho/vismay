# ShortFoot env reference
# Copy the relevant block into apps/worker/.env and apps/mobile/.env
# See docs/plan.md "Environment variables" for details.

# ──────────────────────────────────────────────────────────
# apps/worker/.env  — server-only, never ship to the client
# ──────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...                # service_role key, server-only
GEMINI_API_KEY=                            # aistudio.google.com → Get API key
GEMINI_MODEL=gemini-2.5-flash              # optional override
FOOTBALL_DATA_TOKEN=                       # football-data.org/client/register

# ──────────────────────────────────────────────────────────
# apps/mobile/.env  — EXPO_PUBLIC_* is inlined into the app bundle
# ──────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...       # anon key, safe to ship
