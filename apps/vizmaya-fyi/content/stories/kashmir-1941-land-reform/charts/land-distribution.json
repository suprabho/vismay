{
  "steps": [
    {
      "title": "Where the expropriated land went (lakh acres)",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}: {c} lakh acres"
        },
        "grid": { "left": "3%", "right": "16%", "bottom": "3%", "top": "10%", "containLabel": true },
        "xAxis": {
          "type": "value",
          "min": 0,
          "max": 5,
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": { "color": "$muted", "formatter": "{value} L" },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "category",
          "data": ["Vested in the state", "Transferred to tillers", "Total expropriated"],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": { "color": "$text", "fontSize": 12 },
          "splitLine": { "show": false }
        },
        "series": [
          {
            "name": "Land",
            "type": "bar",
            "barWidth": 22,
            "label": {
              "show": true,
              "position": "right",
              "color": "$text",
              "fontFamily": "Fira Code",
              "fontSize": 12,
              "formatter": "{c} L"
            },
            "data": [
              { "value": 2.2, "itemStyle": { "color": "$muted" } },
              { "value": 2.3, "itemStyle": { "color": "$positive" } },
              { "value": 4.5, "itemStyle": { "color": "$accent" } }
            ]
          }
        ]
      }
    }
  ]
}
