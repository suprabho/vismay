{
  "steps": [
    {
      "title": "Headline project cost, ₹ crore — 2021 to April 2026",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "line" },
          "formatter": "{b}: ₹{c} cr"
        },
        "grid": {
          "left": "3%",
          "right": "8%",
          "bottom": "10%",
          "top": "12%",
          "containLabel": true
        },
        "xAxis": {
          "type": "category",
          "data": [
            "2021 (NITI Aayog)",
            "2022",
            "2025",
            "Apr 2026"
          ],
          "axisLine": { "lineStyle": { "color": "$line" } },
          "axisTick": { "show": false },
          "axisLabel": {
            "color": "$muted",
            "fontFamily": "JetBrains Mono",
            "fontSize": 11
          }
        },
        "yAxis": {
          "type": "value",
          "min": 60000,
          "max": 100000,
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "color": "$muted",
            "formatter": "₹{value} cr",
            "fontFamily": "JetBrains Mono",
            "fontSize": 11
          },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "series": [
          {
            "name": "Cost",
            "type": "line",
            "smooth": false,
            "symbol": "circle",
            "symbolSize": 10,
            "lineStyle": { "color": "$accent", "width": 2 },
            "itemStyle": { "color": "$accent" },
            "label": {
              "show": true,
              "position": "top",
              "color": "$text",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11,
              "formatter": "₹{c}"
            },
            "data": [72000, 75000, 81000, 92500]
          }
        ]
      }
    }
  ]
}
