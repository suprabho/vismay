{
  "steps": [
    {
      "title": "Three segments, three stories — 2025 revenue, USD billions",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}<br/>{a}: ${c}B"
        },
        "grid": { "left": 80, "right": 32, "top": 56, "bottom": 56 },
        "legend": {
          "data": ["Revenue", "Operating Income", "Adj. EBITDA"],
          "textStyle": { "color": "$muted", "fontFamily": "Inter" },
          "top": 12
        },
        "xAxis": {
          "type": "category",
          "data": ["Connectivity (Starlink)", "Space (Falcon · Dragon · Starship)", "AI (xAI · Grok · X)"],
          "axisLabel": {
            "color": "$muted",
            "fontFamily": "Inter",
            "fontSize": 12,
            "interval": 0,
            "overflow": "break"
          },
          "axisLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "value",
          "name": "USD billions",
          "nameTextStyle": { "color": "$muted", "fontFamily": "Inter" },
          "axisLabel": {
            "formatter": "${value}B",
            "color": "$muted",
            "fontFamily": "JetBrains Mono"
          },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "series": [
          {
            "name": "Revenue",
            "type": "bar",
            "data": [11.4, 4.1, 3.2],
            "itemStyle": { "color": "$accent2", "borderRadius": [4, 4, 0, 0] },
            "label": {
              "show": true,
              "position": "top",
              "formatter": "${@[1]}B",
              "color": "$text",
              "fontFamily": "JetBrains Mono"
            }
          },
          {
            "name": "Operating Income",
            "type": "bar",
            "data": [4.4, -0.66, -6.4],
            "itemStyle": {
              "color": "$accent",
              "borderRadius": [4, 4, 0, 0]
            },
            "label": {
              "show": true,
              "position": "top",
              "formatter": "${@[1]}B",
              "color": "$text",
              "fontFamily": "JetBrains Mono"
            }
          },
          {
            "name": "Adj. EBITDA",
            "type": "bar",
            "data": [7.2, -0.2, -5.8],
            "itemStyle": {
              "color": "$positive",
              "borderRadius": [4, 4, 0, 0]
            },
            "label": {
              "show": true,
              "position": "top",
              "formatter": "${@[1]}B",
              "color": "$text",
              "fontFamily": "JetBrains Mono"
            }
          }
        ]
      }
    }
  ]
}
