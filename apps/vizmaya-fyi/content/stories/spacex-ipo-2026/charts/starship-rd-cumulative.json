{
  "steps": [
    {
      "title": "Starship R&D — cumulative spend, USD billions",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "formatter": "{b}<br/>Cumulative: ${c}B"
        },
        "grid": { "left": 64, "right": 32, "top": 56, "bottom": 56 },
        "xAxis": {
          "type": "category",
          "data": ["2019", "2020", "2021", "2022", "2023", "2024", "2025", "Q1 2026"],
          "axisLabel": {
            "color": "$muted",
            "fontFamily": "JetBrains Mono"
          },
          "axisLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "value",
          "name": "USD billions",
          "nameTextStyle": { "color": "$muted", "fontFamily": "Inter" },
          "axisLabel": {
            "formatter": "${value}B",
            "color": "$muted",
            "fontFamily": "JetBrains Mono"
          },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "series": [
          {
            "name": "Cumulative Starship R&D",
            "type": "bar",
            "stack": "cum",
            "barWidth": "55%",
            "itemStyle": {
              "color": "$amber",
              "borderRadius": [4, 4, 0, 0]
            },
            "label": {
              "show": true,
              "position": "top",
              "formatter": "${@[1]}B",
              "color": "$text",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11
            },
            "data": [0.5, 1.3, 2.6, 4.6, 7.5, 11.2, 14.2, 15.13]
          }
        ],
        "graphic": [
          {
            "type": "text",
            "right": 32,
            "top": 84,
            "style": {
              "text": "More than the\noriginal programme budget",
              "fill": "$muted",
              "fontFamily": "Inter",
              "fontSize": 11,
              "textAlign": "right"
            }
          }
        ]
      }
    }
  ]
}
