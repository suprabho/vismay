{
  "steps": [
    {
      "title": "What early-mover finance teams are seeing (manual baseline vs AI-led)",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" }
        },
        "legend": {
          "top": 0,
          "textStyle": { "color": "$muted", "fontSize": 11 }
        },
        "grid": {
          "left": "3%",
          "right": "8%",
          "bottom": "3%",
          "top": "16%",
          "containLabel": true
        },
        "xAxis": {
          "type": "value",
          "max": 100,
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": {
            "formatter": "{value}",
            "color": "$muted"
          },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "category",
          "data": [
            "ITC match rate (%)",
            "GST notices (indexed)",
            "Manual corrections (indexed)",
            "TDS prep (% of manual baseline)",
            "GST prep time (% of 18 days)"
          ],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": { "color": "$text", "fontSize": 11 }
        },
        "series": [
          {
            "name": "Manual baseline",
            "type": "bar",
            "barWidth": 14,
            "itemStyle": {
              "color": "$muted",
              "borderRadius": [0, 3, 3, 0]
            },
            "data": [80, 100, 100, 100, 100]
          },
          {
            "name": "AI-led",
            "type": "bar",
            "barWidth": 14,
            "itemStyle": {
              "color": "$accent",
              "borderRadius": [0, 3, 3, 0]
            },
            "data": [98, 40, 10, 1, 17]
          }
        ]
      }
    }
  ]
}
