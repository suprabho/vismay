              { "value": 8, "itemStyle": { "color": "$red",   "borderRadius": [0,4,4,0] }, "label": { "color": "$red",   "formatter": "8 / 10" } },
              { "value": 9, "itemStyle": { "color": "$red",   "borderRadius": [0,4,4,0] }, "label": { "color": "$red",   "formatter": "9 / 10" } }
