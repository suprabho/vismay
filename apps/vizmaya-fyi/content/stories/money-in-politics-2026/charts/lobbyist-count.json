{
  "steps": [
    {
      "title": "Registered vs. estimated 'shadow' lobbyists",
      "option": {
        "grid": { "left": 150, "right": 80, "top": 40, "bottom": 36 },
        "tooltip": { "trigger": "axis", "formatter": "{b}<br/>{c} lobbyists" },
        "xAxis": {
          "type": "value",
          "axisLabel": { "color": "$muted", "fontFamily": "Inter", "formatter": "{value}" },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "category",
          "data": ["Estimated 'shadow' (Thurber)", "Registered (2024)"],
          "axisLine": { "lineStyle": { "color": "$line" } },
          "axisLabel": { "color": "$text", "fontFamily": "Inter", "fontSize": 12 }
        },
        "series": [
          {
            "type": "bar",
            "barWidth": "52%",
            "data": [
              { "value": 100000, "itemStyle": { "color": "$amber" } },
              { "value": 13007, "itemStyle": { "color": "$accent2" } }
            ],
            "label": {
              "show": true,
              "position": "right",
              "formatter": "{c}",
              "color": "$text",
              "fontFamily": "JetBrains Mono",
              "fontSize": 13,
              "fontWeight": "bold"
            },
            "itemStyle": { "borderRadius": [0, 6, 6, 0] }
          }
        ]
      }
    }
  ]
}
