# apps/render env reference — the brand-neutral headless render surface.
# Copy to apps/render/.env (local) or set in the Vercel project (deploy).
# Surfaces are signed, headless render targets (noindex); no brand chrome.

# ──────────────────────────────────────────────────────────
# Signed-URL gate (middleware.ts) — server-only
# ──────────────────────────────────────────────────────────
# HMAC secret admin signs render URLs with (signOutputUrl). MUST byte-match
# admin's ADMIN_SESSION_SECRET or every signed surface request 401s.
# Unset in local dev → middleware falls through (NODE_ENV !== production);
# prod fails closed. See docs/auth.md (three-scope model).
ADMIN_SESSION_SECRET=

# ──────────────────────────────────────────────────────────
# Content source (surfaces + /api/chart-data) — server-only
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # service_role key, server-only
CONTENT_SOURCE=db                          # db (prod) | fs (local default)
# Local fs only: absolute path to a content/stories dir to render against.
# Defaults to <cwd>/content/stories, which apps/render does not have — point
# it at a consumer app's stories (e.g. apps/vizmaya-fyi/content/stories).
# STORY_CONTENT_DIR=

# ──────────────────────────────────────────────────────────
# Client-injected (lib/env.ts) — NEXT_PUBLIC_* is baked at build time
# ──────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk....            # map-backed surfaces + MapPickerModal
NEXT_PUBLIC_ADMIN_URL=https://vismay.xyz   # editor save fetches target admin; default https://vismay.xyz

# ──────────────────────────────────────────────────────────
# NOTE: the per-surface flip knobs (RENDER_SURFACE_URL_CANVAS_FRAME / _SHARE /
# _SLIDES / _REPORT / _AUTOPLAY) are set on ADMIN, not here — they point admin
# at this app's origin. This app never reads them.
# ──────────────────────────────────────────────────────────
