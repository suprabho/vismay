# Copy to .env and fill in real values. NEVER commit .env.
OTEL_SDK_DISABLED=true

# MongoDB — db name comes from the URI path; must match Backend's MONGODB_URI exactly
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<dbname>?retryWrites=true&w=majority

# Backend callback base URL
BACKEND_API_URL=http://localhost:4000

# Shared secret for X-Worker-Secret header (must match Backend AI_WORKER_SECRET)
AI_WORKER_SECRET=<random-long-secret>

# LLM provider: gemini | ollama | none (mock)
LLM_PROVIDER=none
LLM_TEMPERATURE=0.4

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-2.0-flash
