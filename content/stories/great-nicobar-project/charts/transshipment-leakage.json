{
  "steps": [
    {
      "title": "Estimated share of India-bound transhipment cargo handled at foreign hubs (~75% in total)",
      "option": {
        "tooltip": {
          "trigger": "axis",
          "axisPointer": { "type": "shadow" },
          "formatter": "{b}: ~{c}%"
        },
        "grid": {
          "left": "3%",
          "right": "12%",
          "bottom": "3%",
          "top": "8%",
          "containLabel": true
        },
        "xAxis": {
          "type": "value",
          "min": 0,
          "max": 45,
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": { "color": "$muted", "formatter": "{value}%" },
          "splitLine": { "lineStyle": { "color": "$line" } }
        },
        "yAxis": {
          "type": "category",
          "data": [
            "Salalah",
            "Jebel Ali",
            "Tanjung Pelepas",
            "Port Klang",
            "Singapore",
            "Colombo"
          ],
          "axisLine": { "show": false },
          "axisTick": { "show": false },
          "axisLabel": { "color": "$text", "fontSize": 12 },
          "splitLine": { "show": false }
        },
        "series": [
          {
            "name": "Estimated share",
            "type": "bar",
            "barWidth": 18,
            "label": {
              "show": true,
              "position": "right",
              "color": "$text",
              "fontFamily": "JetBrains Mono",
              "fontSize": 11,
              "formatter": "~{c}%"
            },
            "data": [
              { "value": 3, "itemStyle": { "color": "$muted" } },
              { "value": 5, "itemStyle": { "color": "$muted" } },
              { "value": 4, "itemStyle": { "color": "$muted" } },
              { "value": 5, "itemStyle": { "color": "$muted" } },
              { "value": 19, "itemStyle": { "color": "$accent2" } },
              { "value": 38, "itemStyle": { "color": "$accent" } }
            ]
          }
        ]
      }
    }
  ]
}
